# VPS staging/production environment file (example)
# Install on the server as /etc/offerops/offerops.env (mode 600, root or deploy user).
# Referenced by deploy/systemd/offerops-api.service.example
# Do not commit real secrets.

NODE_ENV=production
PORT=3000

DATABASE_URL=postgres://offerops:replace-me@127.0.0.1:5432/offeropstrex

AUTH_TOKEN_SECRET=replace-with-a-long-random-secret
CORS_ORIGIN=https://staging.offerops.example
SECRETS_ENCRYPTION_KEY=replace-with-a-long-random-secret

ENABLE_VOLUUM=false

LOG_LEVEL=info
APP_VERSION=
DEPLOYMENT_TIMESTAMP=

# Bootstrap — one-time / deployment-only (export in shell for bootstrap command, or uncomment briefly)
# BOOTSTRAP_ADMIN_EMAIL=admin@example.internal
# BOOTSTRAP_ADMIN_PASSWORD=replace-with-a-strong-password
# BOOTSTRAP_ADMIN_NAME=Internal Admin
# BOOTSTRAP_WORKSPACE_NAME=Default Workspace

# Frontend build-time (set in shell when building, not in API EnvironmentFile):
#   VITE_ENABLE_VOLUUM=false BASE_PATH=/ pnpm --filter @workspace/offerops run build

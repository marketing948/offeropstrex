.cache/
.local/
.replit-artifact/

# build / generated
build/
out/
.next/
.vite/
.turbo/
*.tsbuildinfo

# logs
*.log
logs/
/tmp/

# archives — never commit; regenerable on demand
*.tar
*.tar.gz
*.tgz
*.zip
*.7z
*.rar
exports/
dist/

# secrets / env (defense in depth — should never exist anyway)
.env
.env.*
!.env.example
*.pem
*.key
id_rsa
id_rsa.pub
.npmrc.local
secrets.json
credentials.json

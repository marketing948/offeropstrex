# OfferOps environment template
# Copy to a local .env for development or to /etc/offerops/offerops.env on a VPS.
# Do not commit real secrets. See deploy/env/offerops.example.env for a VPS-oriented copy.

# -----------------------------------------------------------------------------
# Runtime (API server) — required for staging/production
# -----------------------------------------------------------------------------

NODE_ENV=production
PORT=3000

# PostgreSQL connection string. On a VPS, use localhost; do not expose Postgres publicly.
DATABASE_URL=postgres://offerops:replace-me@localhost:5432/offeropstrex

# JWT signing secret (required when NODE_ENV=production). Use a long random value.
AUTH_TOKEN_SECRET=

# Comma-separated browser origins allowed to call the API (required in production).
# Example: https://staging.offerops.example
CORS_ORIGIN=https://staging.offerops.example

# AES-256-GCM key material for Voluum credentials at rest (required in production when saving credentials).
SECRETS_ENCRYPTION_KEY=

# -----------------------------------------------------------------------------
# Frontend build-time only (Vite) — set before `pnpm --filter @workspace/offerops run build`
# Changes require a frontend rebuild; they are not read at API runtime.
# -----------------------------------------------------------------------------

VITE_ENABLE_VOLUUM=false

# Vite base path for static assets and router (usually / on VPS behind reverse proxy).
BASE_PATH=/

# -----------------------------------------------------------------------------
# API feature flags (runtime)
# -----------------------------------------------------------------------------

ENABLE_VOLUUM=false

# -----------------------------------------------------------------------------
# Bootstrap — one-time / deployment-only (not needed for normal API restarts)
# Run after migrations on first bring-up or admin recovery:
#   pnpm --filter @workspace/api-server run bootstrap:internal
# -----------------------------------------------------------------------------

BOOTSTRAP_ADMIN_EMAIL=admin@example.internal
BOOTSTRAP_ADMIN_PASSWORD=replace-with-a-strong-password
BOOTSTRAP_ADMIN_NAME=Internal Admin
BOOTSTRAP_WORKSPACE_NAME=Default Workspace

# -----------------------------------------------------------------------------
# Observability (optional)
# -----------------------------------------------------------------------------

LOG_LEVEL=info
APP_VERSION=
DEPLOYMENT_TIMESTAMP=

# -----------------------------------------------------------------------------
# Login rate limiting (optional — defaults: 5 failures / 15 minutes per IP+email)
# -----------------------------------------------------------------------------

# LOGIN_RATE_LIMIT_MAX=5
# LOGIN_RATE_LIMIT_WINDOW_MS=900000
# LOGIN_RATE_LIMIT_DISABLED=true

# -----------------------------------------------------------------------------
# Background crons (optional — single VPS: omit both; crons default on)
# For multiple API replicas: CRON_DISABLED=true on web tier, dedicated worker without it.
# -----------------------------------------------------------------------------

# CRON_DISABLED=true
# CRON_ENABLED=true

# -----------------------------------------------------------------------------
# Graceful shutdown (optional)
# -----------------------------------------------------------------------------

# GRACEFUL_SHUTDOWN_TIMEOUT_MS=25000

# -----------------------------------------------------------------------------
# Voluum sync lock (optional)
# -----------------------------------------------------------------------------

# VOLUUM_SYNC_LOCK_STALE_MS=900000

# -----------------------------------------------------------------------------
# Local development only
# -----------------------------------------------------------------------------

# Vite dev server port (not used for production static build).
# PORT=5173

# Vite dev proxy target when running `pnpm --filter @workspace/offerops run dev`.
# API_PROXY_TARGET=http://localhost:3000

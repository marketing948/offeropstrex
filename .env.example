# Local development defaults only. Do not commit real production secrets.
DATABASE_URL=postgres://offerops:offerops_local_only@localhost:5432/offeropstrex
# Required in production. Dev may omit (server uses a non-production fallback).
AUTH_TOKEN_SECRET=
# Comma-separated browser origins allowed to call the API (required in production).
# Example: http://localhost:5173,https://app.yourdomain.com
CORS_ORIGIN=http://localhost:5173
# Login brute-force protection (defaults: 5 failures / 15 minutes per IP+email).
# LOGIN_RATE_LIMIT_MAX=5
# LOGIN_RATE_LIMIT_WINDOW_MS=900000
# LOGIN_RATE_LIMIT_DISABLED=true
# Required in production when storing Voluum credentials (AES-256-GCM at rest).
SECRETS_ENCRYPTION_KEY=
ENABLE_VOLUUM=false
VITE_ENABLE_VOLUUM=false

# Background crons (API server). In cloud with multiple web replicas, set on web: CRON_DISABLED=true
# so only a dedicated worker runs crons. Local/dev: omit both (crons default on).
# CRON_DISABLED=true
# CRON_ENABLED=true

# Max time (ms) for SIGTERM/SIGINT graceful shutdown before force exit (min 3000; default 25000).
# GRACEFUL_SHUTDOWN_TIMEOUT_MS=25000
